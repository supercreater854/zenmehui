.page { padding: 24rpx 32rpx; min-height: 100vh; background: #f3f4f6; }

.header {
  background: linear-gradient(135deg, #10b981, #14b8a6);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(16,185,129,0.15);
}
.title { font-size: 48rpx; font-weight: 800; color: #fff; }
.subtitle { display: block; margin-top: 8rpx; font-size: 26rpx; color: rgba(255,255,255,0.65); }

.scenes { white-space: nowrap; padding: 8rpx 0 16rpx; }
.scene-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #e5e7eb;
  border-radius: 100rpx;
}
.scene-tag:active { background: #d1fae5; color: #059669; }

.textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 32rpx;
  font-size: 30rpx;
  color: #1f2937;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
}

.intimacy-bar { margin-top: 24rpx; padding: 0 8rpx; }
.intimacy-label { font-size: 26rpx; color: #6b7280; }
.slider { margin: 12rpx 0; }
.intimacy-range { display: flex; justify-content: space-between; font-size: 22rpx; color: #9ca3af; }

.error {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #ef4444;
  background: #fef2f2;
  border-radius: 16rpx;
}

.btn-generate {
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #10b981, #14b8a6);
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(16,185,129,0.2);
}
.btn-generate[disabled] { background: #d1d5db; color: #9ca3af; box-shadow: none; }

.btn-pricing {
  width: 100%;
  margin-top: 20rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #9ca3af;
  background: transparent;
  border: none;
}
.btn-pricing::after { border: none; }

.btn-share {
  width: 100%;
  margin-top: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #9ca3af;
  background: transparent;
  border: none;
}
.btn-share::after { border: none; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
  display: flex; align-items: flex-end;
}
.modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.modal-title { font-size: 34rpx; font-weight: 600; }
.modal-close { font-size: 40rpx; color: #9ca3af; padding: 8rpx; }

.tier-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.tier-card {
  position: relative;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background: #f9fafb;
}
.tier-card:active { border-color: #10b981; }
.tier-highlight { border-color: #10b981; background: #ecfdf5; }
.tier-badge {
  position: absolute; top: -12rpx; left: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx; font-weight: 700;
  color: #fff; background: #10b981; border-radius: 100rpx;
}
.tier-name { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.tier-price { display: block; margin-top: 8rpx; font-size: 36rpx; font-weight: 800; color: #059669; }
.tier-desc { display: block; margin-top: 4rpx; font-size: 22rpx; color: #9ca3af; }
.tier-btn {
  margin-top: 16rpx;
  padding: 12rpx;
  text-align: center;
  font-size: 24rpx; font-weight: 500;
  color: #059669;
  background: #fff;
  border: 1rpx solid #a7f3d0;
  border-radius: 12rpx;
}
.tier-btn-loading { opacity: 0.5; }