<view class="page">
  <view class="bar">
    <navigator class="back-btn" url="/pages/index/index" open-type="navigateBack">返回</navigator>
    <text class="title">我的</text>
    <view></view>
  </view>

  <!-- 用户卡片 -->
  <view class="card">
    <view class="user-row">
      <view class="avatar">匿</view>
      <view class="user-info">
        <text class="user-name">匿名用户</text>
        <text class="user-id">ID: {{userId}}</text>
      </view>
    </view>
    <view class="stats">
      <view class="stat">
        <text class="stat-num">{{contactCount}}</text>
        <text class="stat-label">联系人</text>
      </view>
      <view class="stat">
        <text class="stat-num emerald">{{creditsLabel}}</text>
        <text class="stat-label">剩余积分</text>
      </view>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu">
    <navigator class="menu-item" url="/pages/contacts/contacts">
      <text>联系人管理</text>
      <text class="menu-hint">{{contactCount}}人</text>
    </navigator>
    <view class="menu-item" bindtap="onExportContacts">
      <text>导出联系人数据</text>
      <text class="menu-hint">备份</text>
    </view>
    <view class="menu-item danger" bindtap="onClearData">
      <text>清除所有数据</text>
    </view>
  </view>

  <navigator class="home-link" url="/pages/index/index" open-type="navigateBack">返回首页</navigator>
</view>