.page { padding: 0 32rpx; min-height: 100vh; background: #f3f4f6; }
.bar { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; margin-bottom: 24rpx; }
.back-btn { font-size: 28rpx; color: #9ca3af; }
.title { font-size: 34rpx; font-weight: 600; color: #1f2937; }

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.label { font-size: 26rpx; color: #6b7280; margin-bottom: 12rpx; display: block; }
.input {
  padding: 20rpx;
  font-size: 30rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
}

.relation-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.rel-tag {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 100rpx;
}
.rel-active { color: #059669; background: #d1fae5; border: 1rpx solid #a7f3d0; }

.btn-save {
  width: 100%; margin-top: 24rpx; padding: 24rpx;
  font-size: 30rpx; font-weight: 600; color: #fff;
  background: linear-gradient(135deg, #10b981, #14b8a6);
  border: none; border-radius: 20rpx;
}
.btn-save::after { border: none; }

.btn-delete {
  width: 100%; margin-top: 16rpx; padding: 24rpx;
  font-size: 28rpx; color: #ef4444;
  background: #fef2f2;
  border: none; border-radius: 20rpx;
}
.btn-delete::after { border: none; }