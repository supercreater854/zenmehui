.page { padding: 0 32rpx; min-height: 100vh; background: #f3f4f6; }
.bar { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; }
.back-btn { font-size: 28rpx; color: #9ca3af; }
.title { font-size: 34rpx; font-weight: 600; color: #1f2937; }
.new-btn { font-size: 28rpx; color: #059669; font-weight: 500; }

.new-card { margin-bottom: 24rpx; padding: 24rpx; background: #fff; border-radius: 20rpx; }
.new-input {
  padding: 20rpx; font-size: 28rpx;
  background: #f3f4f6; border-radius: 16rpx;
}
.new-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.new-confirm {
  flex: 1; padding: 20rpx; font-size: 28rpx; font-weight: 600; color: #fff;
  background: linear-gradient(135deg, #10b981, #14b8a6);
  border: none; border-radius: 16rpx;
}
.new-cancel {
  flex: 1; padding: 20rpx; font-size: 28rpx; color: #6b7280;
  background: #e5e7eb; border: none; border-radius: 16rpx;
}
.new-confirm::after, .new-cancel::after { border: none; }

.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
.empty-text { font-size: 28rpx; color: #9ca3af; }
.empty-btn {
  margin-top: 24rpx; padding: 16rpx 40rpx;
  font-size: 28rpx; font-weight: 500; color: #fff;
  background: linear-gradient(135deg, #10b981, #14b8a6);
  border: none; border-radius: 20rpx;
}
.empty-btn::after { border: none; }

.list { display: flex; flex-direction: column; gap: 12rpx; }
.contact-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: #e5e7eb;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600; color: #6b7280;
  flex-shrink: 0;
}
.info { flex: 1; min-width: 0; }
.name { font-size: 30rpx; font-weight: 500; color: #1f2937; display: block; }
.meta { font-size: 24rpx; color: #9ca3af; margin-top: 4rpx; display: block; }
.del-btn { font-size: 36rpx; color: #d1d5db; padding: 8rpx; }